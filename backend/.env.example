# Backend Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
PRODUCTION_BUILD=true

# Database
DB_PORT=27017
DB_NAME=shobaz
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
AUTH_SOURCE=admin

# JWT Secrets
JWT_PRIVATE_KEY_USER=your_user_jwt_secret
JWT_PRIVATE_KEY_ADMIN=your_admin_jwt_secret

# SSL Payment
STORE_ID=your_store_id
STORE_PASSWORD=your_store_password

# Google OAuth
GOOGLE_CLIENT_ID_1=your_client_id
GOOGLE_CLIENT_SECRET_1=your_client_secret
GOOGLE_REFRESH_TOKEN_1=your_refresh_token
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# SMS
SMS_API_TOKEN=your_api_token
SMS_SID=your_sid
SMS_USERNAME=your_username
SMS_SECRET=your_secret
SMS_PASSWORD=your_password
SMS_ID=your_id

# Google Drive Backup
DRIVE_FOLDER_ID=your_google_drive_folder_id

# Gmail
GMAIL=your-email@gmail.com
ACCOUNT_GMAIL=your-email@gmail.com